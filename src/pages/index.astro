---
import ToolLayout from "../layouts/ToolLayout.astro";
import LoadingStages from "../components/LoadingStages.astro";
import RateLimitWall from "../components/RateLimitWall.astro";
import ShotResult from "../components/ShotResult.astro";
import { SHOT_SAMPLES } from "../fixtures/studio-north";

const REPO_URL = "https://github.com/Voxlabs-Live/shot-list";

const FORMATS = [
  "9:16 reel (15-30s)",
  "9:16 reel (60s)",
  "16:9 commercial (30s)",
  "16:9 commercial (60s)",
];
---
<ToolLayout
  toolName="Shot List"
  description="Paste a script or concept, get a structured shot list — shot #, action, framing, duration, audio, transition. Render-engine-agnostic. Part of the Agency Vibe-Coding Kit."
  repoUrl={REPO_URL}
>
  <h1 class="tool-title">
    From a paragraph of script to a <em>shoot-day shot list</em>.
  </h1>
  <p class="tool-lede">
    Paste a script or concept and pick the format. The tool returns a structured
    shot list — numbered, framed, timed, audio-cued, with optional shader
    transitions for Hyperframes assembly downstream.
  </p>

  <!-- ─── Project library ──────────────────────────────────────────────── -->
  <section class="projects" data-projects>
    <div class="projects__row">
      <label class="projects__label" for="project-picker">Project</label>
      <select class="input projects__picker" id="project-picker" data-project-picker></select>
      <button class="btn btn--ghost btn--small" data-project-new>+ New</button>
      <button class="btn btn--ghost btn--small" data-project-duplicate>Duplicate</button>
      <button class="btn btn--ghost btn--small" data-project-delete>Delete</button>
    </div>
    <div class="projects__row projects__row--name" data-project-name-row hidden>
      <label class="projects__label" for="project-name">Name</label>
      <input
        class="input projects__name"
        id="project-name"
        data-project-name
        type="text"
        maxlength="120"
        placeholder="Project name"
      />
    </div>
    <span class="projects__status" data-project-status></span>
  </section>

  <section class="card">
    {SHOT_SAMPLES.length > 0 && (
      <div class="samples">
        <span class="samples__label">Try a sample:</span>
        {SHOT_SAMPLES.map((s) => (
          <button class="btn btn--ghost btn--small" data-sample={s.id}>
            {s.client}
          </button>
        ))}
      </div>
    )}

    <div class="field-group">
      <label class="field-label" for="format">
        Format
        <span class="field-hint">Target duration window drives the per-shot timing budget</span>
      </label>
      <select class="input" id="format" name="format">
        {FORMATS.map((f) => <option value={f}>{f}</option>)}
      </select>
    </div>

    <div class="field-group">
      <label class="field-label" for="concept">
        Concept or script
        <span class="field-hint">Paste a written script (V/O + action), a high-level concept, or both</span>
      </label>
      <textarea
        class="input"
        id="concept"
        name="concept"
        placeholder={"Aurelia Lashes — before/after reveal of a returning client's first set after a 6-week break. Open on her closed eyes mid-application, end on her seeing herself in the mirror. No V/O — pure sound design..."}
        rows="11"
      ></textarea>
    </div>

    <div class="actions">
      <button class="btn btn--primary" id="submit">Generate shot list &rarr;</button>
      <LoadingStages stages={["Reading", "Planning", "Done"]} />
      <span class="actions__hint" id="hint"></span>
    </div>
  </section>

  <ShotResult />
  <RateLimitWall repoUrl={REPO_URL} />

  <!-- Term explainer popover — opens on clicking a framing/transition chip. -->
  <div class="term-pop" data-term-pop hidden role="dialog" aria-label="Shot list term explanation">
    <button type="button" class="term-pop__close" data-term-pop-close aria-label="Close">&times;</button>
    <p class="term-pop__title" data-term-pop-title></p>
    <code class="term-pop__token" data-term-pop-token></code>
    <p class="term-pop__blurb" data-term-pop-blurb></p>
    <p class="term-pop__example" data-term-pop-example></p>
  </div>

  <!-- Confirmation modal — replaces native confirm() for destructive actions. -->
  <div class="confirm" data-confirm-modal hidden>
    <div class="confirm__backdrop" data-confirm-cancel></div>
    <div class="confirm__card" role="dialog" aria-modal="true" aria-labelledby="confirm-title" aria-describedby="confirm-body">
      <h3 class="confirm__title" id="confirm-title" data-confirm-title>Are you sure?</h3>
      <p class="confirm__body" id="confirm-body" data-confirm-body></p>
      <div class="confirm__actions">
        <button type="button" class="btn btn--ghost btn--small" data-confirm-cancel>Cancel</button>
        <button type="button" class="btn btn--small confirm__danger" data-confirm-ok>Confirm</button>
      </div>
    </div>
  </div>
</ToolLayout>

<style>
  .field-group { margin-bottom: 1rem; }
  .field-group:last-of-type { margin-bottom: 1.25rem; }

  /* ─── Project library bar ───────────────────────────────────────────── */
  .projects {
    background: var(--surface-0);
    border: 1px solid var(--surface-200);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-card);
  }
  .projects__row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .projects__row--name { margin-top: 0.6rem; }
  .projects__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--surface-500);
    flex: 0 0 auto;
  }
  .projects__picker { flex: 1 1 16rem; min-width: 12rem; }
  .projects__name { flex: 1 1 16rem; min-width: 12rem; }
  .projects__name[readonly] {
    background: var(--surface-50);
    color: var(--surface-500);
    cursor: not-allowed;
  }
  .projects__status {
    display: inline-block;
    margin-top: 0.5rem;
    min-height: 1.1em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--surface-600);
  }
  .projects__status[data-state="saved"] { color: var(--accent-700); }
  .projects__status[data-state="warn"] { color: var(--amber-700, var(--surface-700)); }

  /* ─── Confirmation modal ─────────────────────────────────────────────── */
  .confirm {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }
  .confirm__backdrop {
    position: absolute;
    inset: 0;
    background: oklch(0.18 0.012 60 / 0.45);
    backdrop-filter: blur(2px);
    animation: confirm-fade var(--duration-base) var(--ease-smooth);
  }
  .confirm__card {
    position: relative;
    width: 100%;
    max-width: 26rem;
    background: var(--surface-0);
    border: 1px solid var(--surface-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    padding: 1.5rem 1.6rem 1.35rem;
    animation: confirm-pop var(--duration-base) var(--ease-spring);
  }
  .confirm__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--surface-900);
    margin: 0 0 0.55rem;
  }
  .confirm__body {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--surface-700);
    margin: 0 0 1.35rem;
  }
  .confirm__actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
  }
  .confirm__danger {
    background: var(--accent-600);
    color: var(--surface-0);
    box-shadow: var(--shadow-cta);
  }
  .confirm__danger:hover { background: var(--accent-700); color: var(--surface-0); }

  @keyframes confirm-fade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes confirm-pop {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .confirm__backdrop, .confirm__card { animation: none; }
  }

  /* ─── Term explainer popover ────────────────────────────────────────── */
  .term-pop {
    position: fixed;
    z-index: 1100;
    width: min(20rem, calc(100vw - 1.5rem));
    background: var(--surface-0);
    border: 1px solid var(--surface-300);
    border-radius: var(--radius);
    box-shadow: var(--shadow-xl, var(--shadow-card));
    padding: 0.9rem 1rem 1rem;
  }
  .term-pop__close {
    position: absolute;
    top: 0.35rem;
    right: 0.45rem;
    background: none;
    border: 0;
    font-size: 1.2rem;
    line-height: 1;
    color: var(--surface-500);
    cursor: pointer;
    padding: 0.2rem 0.35rem;
    border-radius: var(--radius-sm, 4px);
  }
  .term-pop__close:hover { color: var(--surface-900); background: var(--surface-100); }
  .term-pop__title {
    font-family: var(--font-display);
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-base);
    color: var(--surface-900);
    margin: 0 1.5rem 0.15rem 0;
  }
  .term-pop__token {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-800);
    background: oklch(from var(--accent-100) l c h / 0.6);
    border: 1px solid oklch(from var(--accent-500) l c h / 0.3);
    border-radius: var(--radius-sm, 4px);
    padding: 0.05rem 0.4rem;
  }
  .term-pop__token:empty { display: none; }
  .term-pop__blurb {
    margin: 0.55rem 0 0.35rem;
    font-size: var(--text-sm);
    color: var(--surface-700);
    line-height: var(--leading-relaxed);
  }
  .term-pop__example {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--surface-500);
    font-style: italic;
  }
  .term-pop__example:empty { display: none; }
</style>

<script>
  import { SHOT_SAMPLES } from "../fixtures/studio-north";
  import type { ShotListResult, Shot } from "../lib/shot-types";
  import type { ApiResponse } from "../lib/types";
  import { transitionEntry, matchFraming, type GlossaryEntry } from "../lib/shot-glossary";
  import { toMarkdown, toPrintHtml, type ExportResult } from "../lib/shot-export";
  import {
    seedSamplesIfNeeded,
    buildSampleProjects,
    listProjects,
    getProject,
    saveProject,
    deleteProject,
    renameProject,
    duplicateProject,
    autoName,
    setLastViewed,
    getLastViewedId,
    isSampleId,
    type Project,
    type StoredResult,
  } from "../lib/project-storage";

  type GenData = ShotListResult & {
    duration_drift?: boolean;
    target_duration_sec?: number;
  };

  const $ = (sel: string) => document.querySelector(sel) as HTMLElement | null;
  const formatEl = $("#format") as HTMLSelectElement;
  const conceptEl = $("#concept") as HTMLTextAreaElement;
  const submit = $("#submit") as HTMLButtonElement;
  const hint = $("#hint");
  const loading = document.querySelector(".loading") as HTMLElement | null;
  const result = document.querySelector(".result") as HTMLElement | null;
  const wall = document.querySelector(".wall") as HTMLElement | null;

  // Project library controls.
  const picker = $("[data-project-picker]") as HTMLSelectElement;
  const nameRow = $("[data-project-name-row]") as HTMLElement;
  const nameInput = $("[data-project-name]") as HTMLInputElement;
  const newBtn = $("[data-project-new]") as HTMLButtonElement;
  const dupBtn = $("[data-project-duplicate]") as HTMLButtonElement;
  const delBtn = $("[data-project-delete]") as HTMLButtonElement;
  const projStatus = $("[data-project-status]") as HTMLElement;

  /** The active project's id, or null when the inputs hold an unsaved draft. */
  let currentProjectId: string | null = null;
  /** Drives the result header's client label. */
  let lastClientName = "";
  /** Debounced-rename state. Declared up here so the bootstrap restore (which
   *  calls openProject → flushRename) doesn't hit a temporal dead zone. */
  let renameTimer: number | undefined;
  let pendingRename: { id: string; value: string } | null = null;

  function setStatus(message: string, state?: "saved" | "warn"): void {
    projStatus.textContent = message;
    if (state) projStatus.dataset.state = state;
    else delete projStatus.dataset.state;
  }

  // ─── Picker population ────────────────────────────────────────────────
  function populatePicker(): void {
    const projects = listProjects();
    picker.innerHTML = "";
    if (currentProjectId === null) {
      const opt = document.createElement("option");
      opt.value = "";
      opt.textContent = "— Unsaved draft —";
      picker.appendChild(opt);
    }
    for (const p of projects) {
      const opt = document.createElement("option");
      opt.value = p.id;
      // textContent => XSS-safe with user-supplied / sample names.
      opt.textContent = isSampleId(p.id) ? `${p.name} — sample` : p.name;
      picker.appendChild(opt);
    }
    picker.value = currentProjectId ?? "";
  }

  /** Reflect the current project's editable state in name input + buttons. */
  function refreshControls(): void {
    const sample = isSampleId(currentProjectId ?? "");
    const hasProject = currentProjectId !== null;
    nameRow.hidden = !hasProject;
    if (hasProject) {
      const proj = getProject(currentProjectId as string);
      nameInput.value = proj?.name ?? "";
      nameInput.readOnly = sample;
      nameInput.title = sample ? "Sample projects are read-only — Duplicate to edit" : "";
    }
    dupBtn.disabled = !hasProject;
    delBtn.disabled = !hasProject;
  }

  /** Hide + clear the result panel so a stale list can't apply to a new item. */
  function clearResultPanel(): void {
    if (result) result.hidden = true;
    const shotsEl = result?.querySelector('[data-field="shots"]') as HTMLElement | null;
    if (shotsEl) shotsEl.innerHTML = "";
    delete (window as any).__lastResult;
  }

  // ─── Open / new / load ────────────────────────────────────────────────
  function openProject(id: string): void {
    flushRename(); // persist any pending rename for the doc we're leaving
    const proj = getProject(id);
    if (!proj) return;
    currentProjectId = proj.id;
    formatEl.value = proj.format || formatEl.value;
    conceptEl.value = proj.concept;
    lastClientName = isSampleId(proj.id) ? proj.name : proj.name || "your spot";
    if (proj.result && Array.isArray(proj.result.shots) && proj.result.shots.length > 0) {
      (window as any).__lastResult = proj.result;
      render(proj.result as GenData);
    } else {
      clearResultPanel();
    }
    setLastViewed(proj.id);
    populatePicker();
    refreshControls();
    setStatus(isSampleId(proj.id) ? "Sample — generate to save your own copy" : "");
  }

  function newProject(): void {
    flushRename();
    currentProjectId = null;
    conceptEl.value = "";
    lastClientName = "";
    clearResultPanel();
    if (wall) wall.hidden = true;
    if (hint) hint.textContent = "";
    populatePicker();
    refreshControls();
    setStatus("New draft — generate to save it.");
    conceptEl.focus();
  }

  // ─── Bootstrap ────────────────────────────────────────────────────────
  seedSamplesIfNeeded(buildSampleProjects(SHOT_SAMPLES));
  populatePicker();
  refreshControls();
  (() => {
    const lastId = getLastViewedId();
    if (lastId && getProject(lastId)) openProject(lastId);
    else setStatus("");
  })();

  // Last-resort flush so a refresh during the rename debounce isn't lost.
  window.addEventListener("beforeunload", flushRename);

  // ─── Sample quick-buttons → open the matching sample project ──────────
  document.querySelectorAll<HTMLButtonElement>("[data-sample]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.sample;
      const sample = SHOT_SAMPLES.find((s) => s.id === id);
      if (sample) openProject(`sample:${sample.id}`);
    });
  });

  // ─── Picker / new / duplicate / delete / rename ──────────────────────
  picker.addEventListener("change", () => {
    const id = picker.value;
    if (!id) return; // "Unsaved draft" placeholder
    openProject(id);
  });

  newBtn.addEventListener("click", newProject);

  dupBtn.addEventListener("click", () => {
    if (!currentProjectId) return;
    const copy = duplicateProject(currentProjectId);
    if (copy) {
      openProject(copy.id);
      setStatus(`Duplicated as "${copy.name}".`, "saved");
    }
  });

  // Capture the project id + value at edit time so a fast switch mid-debounce
  // can't apply a pending rename to the WRONG (newly-selected) project.
  function applyRename(id: string, value: string): void {
    const name = value.trim() || "Untitled project";
    renameProject(id, name);
    const opt = [...picker.options].find((o) => o.value === id);
    if (opt) opt.textContent = name; // textContent => XSS-safe
    if (currentProjectId === id) lastClientName = name;
    setStatus("Renamed.", "saved");
  }

  /** Persist a pending rename immediately — call before any project switch/unload. */
  function flushRename(): void {
    window.clearTimeout(renameTimer);
    if (pendingRename) {
      applyRename(pendingRename.id, pendingRename.value);
      pendingRename = null;
    }
  }

  nameInput.addEventListener("input", () => {
    if (!currentProjectId || isSampleId(currentProjectId)) return;
    pendingRename = { id: currentProjectId, value: nameInput.value };
    window.clearTimeout(renameTimer);
    renameTimer = window.setTimeout(flushRename, 400);
  });

  delBtn.addEventListener("click", async () => {
    if (!currentProjectId) return;
    if (isSampleId(currentProjectId)) {
      setStatus("Sample projects are read-only — Duplicate to make an editable copy.", "warn");
      return;
    }
    const proj = getProject(currentProjectId);
    if (!proj) return;
    const ok = await openConfirm({
      title: "Delete this project?",
      body: `“${proj.name}” and its shot list will be permanently removed. This can't be undone.`,
      confirmText: "Delete",
    });
    if (!ok) return;
    deleteProject(currentProjectId);
    // Reset cleanly to the most-recent remaining project, else a fresh draft.
    const remaining = listProjects();
    if (remaining.length > 0) {
      openProject(remaining[0].id);
    } else {
      newProject();
    }
    setStatus("Deleted.", "saved");
  });

  // ─── Confirm modal (in-app replacement for native confirm()) ─────────
  const confirmEl = document.querySelector("[data-confirm-modal]") as HTMLElement | null;
  const confirmTitle = confirmEl?.querySelector("[data-confirm-title]") as HTMLElement | null;
  const confirmBody = confirmEl?.querySelector("[data-confirm-body]") as HTMLElement | null;
  const confirmOk = confirmEl?.querySelector("[data-confirm-ok]") as HTMLButtonElement | null;
  const confirmCancelBtn = confirmEl?.querySelector("button[data-confirm-cancel]") as HTMLButtonElement | null;
  let confirmResolve: ((v: boolean) => void) | null = null;
  let confirmLastFocus: HTMLElement | null = null;

  function closeConfirm(value: boolean): void {
    if (!confirmEl) return;
    confirmEl.hidden = true;
    const resolve = confirmResolve;
    confirmResolve = null;
    confirmLastFocus?.focus?.();
    resolve?.(value);
  }

  function openConfirm(opts: { title?: string; body: string; confirmText?: string }): Promise<boolean> {
    if (!confirmEl || !confirmTitle || !confirmBody || !confirmOk) {
      return Promise.resolve(window.confirm(opts.body));
    }
    confirmTitle.textContent = opts.title ?? "Are you sure?";
    confirmBody.textContent = opts.body; // textContent => XSS-safe
    confirmOk.textContent = opts.confirmText ?? "Confirm";
    confirmLastFocus = document.activeElement as HTMLElement;
    confirmEl.hidden = false;
    confirmCancelBtn?.focus();
    return new Promise((resolve) => { confirmResolve = resolve; });
  }

  confirmOk?.addEventListener("click", () => closeConfirm(true));
  confirmEl?.querySelectorAll("[data-confirm-cancel]").forEach((el) =>
    el.addEventListener("click", () => closeConfirm(false))
  );
  document.addEventListener("keydown", (e) => {
    if (confirmEl && !confirmEl.hidden && e.key === "Escape") {
      e.preventDefault();
      closeConfirm(false);
    }
  });

  // ─── Term explainer popover ───────────────────────────────────────────
  // Framing tags and transition chips open a small in-context card with a
  // plain-English definition. The full set also lives in the collapsible
  // "Shot list terms, explained" glossary under the result.
  const termPop = document.querySelector("[data-term-pop]") as HTMLElement | null;
  const popTitle = termPop?.querySelector("[data-term-pop-title]") as HTMLElement | null;
  const popToken = termPop?.querySelector("[data-term-pop-token]") as HTMLElement | null;
  const popBlurb = termPop?.querySelector("[data-term-pop-blurb]") as HTMLElement | null;
  const popExample = termPop?.querySelector("[data-term-pop-example]") as HTMLElement | null;
  let popAnchor: HTMLElement | null = null;

  /** Turn a chip into a keyboard- and pointer-accessible explainer trigger. */
  function makeChipInteractive(el: HTMLElement, entry: GlossaryEntry): void {
    el.setAttribute("role", "button");
    el.setAttribute("tabindex", "0");
    el.setAttribute("aria-label", `What is ${entry.title}?`);
    el.addEventListener("click", (e) => {
      e.stopPropagation();
      openTermPopover(entry, el);
    });
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openTermPopover(entry, el);
      }
    });
  }

  function openTermPopover(entry: GlossaryEntry, anchor: HTMLElement): void {
    if (!termPop || !popTitle || !popToken || !popBlurb || !popExample) return;
    popTitle.textContent = entry.title;
    // Only transitions carry a canonical enum token worth surfacing.
    popToken.textContent = entry.token.includes("_") ? entry.token : "";
    popBlurb.textContent = entry.blurb; // textContent => XSS-safe
    popExample.textContent = entry.example ? `e.g. ${entry.example}` : "";
    popAnchor = anchor;
    termPop.hidden = false;
    positionTermPop(anchor);
    (termPop.querySelector("[data-term-pop-close]") as HTMLButtonElement | null)?.focus();
  }

  function closeTermPopover(returnFocus = true): void {
    if (!termPop || termPop.hidden) return;
    termPop.hidden = true;
    const a = popAnchor;
    popAnchor = null;
    if (returnFocus) a?.focus?.();
  }

  function positionTermPop(anchor: HTMLElement): void {
    if (!termPop) return;
    const r = anchor.getBoundingClientRect();
    const pw = termPop.offsetWidth;
    const ph = termPop.offsetHeight;
    let left = r.left;
    if (left + pw > window.innerWidth - 12) left = window.innerWidth - 12 - pw;
    if (left < 12) left = 12;
    let top = r.bottom + 8;
    if (top + ph > window.innerHeight - 12) top = r.top - 8 - ph; // flip above
    if (top < 12) top = 12;
    termPop.style.left = `${left}px`;
    termPop.style.top = `${top}px`;
  }

  termPop?.querySelector("[data-term-pop-close]")?.addEventListener("click", () => closeTermPopover());
  // Click anywhere outside closes it (chip clicks stopPropagation, so they don't).
  document.addEventListener("click", (e) => {
    if (termPop && !termPop.hidden && !termPop.contains(e.target as Node)) {
      closeTermPopover(false);
    }
  });
  document.addEventListener("keydown", (e) => {
    if (termPop && !termPop.hidden && e.key === "Escape") {
      e.preventDefault();
      closeTermPopover();
    }
  });
  // A floating fixed popover would drift on scroll/resize — just close it.
  window.addEventListener("scroll", () => closeTermPopover(false), true);
  window.addEventListener("resize", () => closeTermPopover(false));

  // ─── Copy buttons ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const data = (window as any).__lastResult as GenData | undefined;
      if (!data) return;
      // Copy JSON emits ONLY the canonical, render-engine-agnostic schema —
      // never the internal duration_drift / target_duration_sec UI flags.
      const cleanJson = {
        format: data.format,
        total_duration_sec: data.total_duration_sec,
        shot_count: data.shot_count,
        shots: data.shots,
      };
      const text = btn.dataset.copy === "json" ? JSON.stringify(cleanJson, null, 2) : formatPlain(data);
      navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = "Copied!";
      setTimeout(() => (btn.textContent = orig), 1400);
    });
  });

  // ─── Export buttons (Markdown download + Save-as-PDF) ─────────────────
  /** The display/title name for an export — the project name, else a fallback. */
  function exportName(): string {
    return lastClientName && lastClientName !== "your spot" ? lastClientName : "shot-list";
  }
  /** Filesystem-safe slug for download filenames. */
  function slugify(name: string): string {
    return (
      name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "")
        .slice(0, 60) || "shot-list"
    );
  }

  document.querySelectorAll<HTMLButtonElement>("[data-export]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const data = (window as any).__lastResult as GenData | undefined;
      if (!data) return;
      const name = exportName();
      if (btn.dataset.export === "md") {
        const md = toMarkdown(data as unknown as ExportResult, name);
        const blob = new Blob([md], { type: "text/markdown;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${slugify(name)}-shot-list.md`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        const orig = btn.textContent;
        btn.textContent = "Downloaded!";
        setTimeout(() => (btn.textContent = orig), 1400);
      } else if (btn.dataset.export === "pdf") {
        // Open a clean, self-contained print document so "Save as PDF" yields a
        // formatted PDF without the app chrome — no extra dependency. A Blob URL
        // (rather than document.write) keeps it same-origin and non-deprecated.
        const html = toPrintHtml(data as unknown as ExportResult, name);
        const url = URL.createObjectURL(new Blob([html], { type: "text/html" }));
        const win = window.open(url, "_blank");
        if (!win) {
          if (hint) hint.textContent = "Allow pop-ups to save the PDF, then try again.";
          URL.revokeObjectURL(url);
          return;
        }
        win.focus();
        // Let the new tab render the blob, then open its print dialog.
        setTimeout(() => { try { win.print(); } catch { /* user can print manually */ } }, 500);
        setTimeout(() => URL.revokeObjectURL(url), 60_000);
      }
    });
  });

  // ─── Generate ─────────────────────────────────────────────────────────
  submit.addEventListener("click", async () => {
    const concept = conceptEl.value.trim();
    const format = formatEl.value;
    if (!concept) {
      conceptEl.focus();
      return;
    }

    submit.disabled = true;
    if (hint) hint.textContent = "";
    if (result) result.hidden = true;
    if (wall) wall.hidden = true;
    if (loading) {
      loading.hidden = false;
      loading.dataset.stage = "reading";
    }
    const t1 = window.setTimeout(() => {
      if (loading) loading.dataset.stage = "extracting";
    }, 1000);

    try {
      const res = await fetch("/api/generate", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ concept, format }),
      });
      const payload = (await res.json()) as ApiResponse<GenData>;
      window.clearTimeout(t1);

      if (!payload.ok) {
        if (payload.error === "rate_limit_exceeded" && wall) {
          wall.hidden = false;
          wall.scrollIntoView({ behavior: "smooth", block: "start" });
        } else if (hint) {
          hint.textContent = payload.message;
        }
        return;
      }

      if (loading) loading.dataset.stage = "done";
      (window as any).__lastResult = payload.data;
      persistGenerated(concept, format, payload.data);
      render(payload.data);
      if (hint && Number.isFinite(payload.remaining) && payload.remaining >= 0) {
        hint.textContent =
          payload.remaining > 0
            ? `${payload.remaining} demo run${payload.remaining === 1 ? "" : "s"} remaining`
            : "Last demo run used — fork to keep going.";
      }
    } catch {
      if (hint) hint.textContent = "Network error. Try again.";
    } finally {
      submit.disabled = false;
      window.setTimeout(() => {
        if (loading) loading.hidden = true;
      }, 600);
    }
  });

  /**
   * Save the generated shot list to a project so it survives refresh.
   * - Editing an existing user project → update it in place.
   * - Fresh draft, or a read-only sample → create a new auto-named project.
   */
  function persistGenerated(concept: string, format: string, data: GenData): void {
    const stored: StoredResult = {
      format: data.format,
      total_duration_sec: data.total_duration_sec,
      shot_count: data.shot_count,
      shots: data.shots,
      duration_drift: data.duration_drift,
      target_duration_sec: data.target_duration_sec,
    };
    let project: Project;
    if (currentProjectId && !isSampleId(currentProjectId) && getProject(currentProjectId)) {
      const existing = getProject(currentProjectId) as Project;
      project = saveProject({ ...existing, concept, format, result: stored });
    } else {
      // Generating off a read-only sample graduates it to an editable project.
      // Keep the sample's clean client name rather than the long concept line.
      const fromSample =
        currentProjectId && isSampleId(currentProjectId) ? getProject(currentProjectId) : undefined;
      project = saveProject({
        id: crypto.randomUUID(),
        name: fromSample ? fromSample.name : autoName(concept),
        concept,
        format,
        result: stored,
        updated_at: new Date().toISOString(),
      });
      lastClientName = project.name;
    }
    currentProjectId = project.id;
    setLastViewed(project.id);
    populatePicker();
    refreshControls();
    setStatus("✓ Saved — survives refresh", "saved");
  }

  // ─── Render ───────────────────────────────────────────────────────────
  function render(data: GenData) {
    if (!result) return;
    result.hidden = false;

    const clientEl = result.querySelector('[data-field="client"]') as HTMLElement;
    clientEl.textContent = lastClientName || "your spot";

    (result.querySelector('[data-field="format"]') as HTMLElement).textContent = data.format;
    (result.querySelector('[data-field="total"]') as HTMLElement).textContent =
      data.total_duration_sec.toFixed(1);
    (result.querySelector('[data-field="count"]') as HTMLElement).textContent =
      String(data.shot_count);

    const driftEl = result.querySelector('[data-field="drift"]') as HTMLElement;
    driftEl.hidden = !data.duration_drift;

    const shotsEl = result.querySelector('[data-field="shots"]') as HTMLElement;
    shotsEl.innerHTML = "";
    data.shots.forEach((s) => shotsEl.appendChild(renderShot(s)));

    result.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function renderShot(s: Shot): HTMLLIElement {
    const li = document.createElement("li");

    const num = document.createElement("div");
    num.className = "shot-num";
    num.textContent = String(s.shot_number).padStart(2, "0");

    const body = document.createElement("div");
    body.className = "shot-body";

    const meta = document.createElement("div");
    meta.className = "shot-meta";
    meta.appendChild(chip(`${s.duration_sec.toFixed(1)}s`, "chip chip--duration"));

    // Framing chip — wire an explainer popover when we recognize the term.
    const framingChip = chip(s.framing, "chip");
    const framingEntry = matchFraming(s.framing);
    if (framingEntry) makeChipInteractive(framingChip, framingEntry);
    meta.appendChild(framingChip);

    // Transition chip — only shown for a real (non-cut) shader transition.
    if (s.transition_in && s.transition_in !== "cut") {
      const transChip = chip(`→ ${s.transition_in}`, "chip chip--transition");
      const transEntry = transitionEntry(s.transition_in);
      if (transEntry) makeChipInteractive(transChip, transEntry);
      meta.appendChild(transChip);
    }
    body.appendChild(meta);

    const action = document.createElement("p");
    action.className = "shot-action";
    action.textContent = s.action;
    body.appendChild(action);

    const audio = document.createElement("p");
    audio.className = "shot-audio";
    const audioLabel = document.createElement("span");
    audioLabel.className = "shot-audio-label";
    audioLabel.textContent = "Audio";
    audio.appendChild(audioLabel);
    audio.appendChild(document.createTextNode(s.audio));
    body.appendChild(audio);

    if (s.notes) {
      const notes = document.createElement("p");
      notes.className = "shot-notes";
      const notesLabel = document.createElement("span");
      notesLabel.className = "shot-notes-label";
      notesLabel.textContent = "Note";
      notes.appendChild(notesLabel);
      notes.appendChild(document.createTextNode(s.notes));
      body.appendChild(notes);
    }

    li.appendChild(num);
    li.appendChild(body);
    return li;
  }

  function chip(text: string, className: string): HTMLSpanElement {
    const span = document.createElement("span");
    span.className = className;
    span.textContent = text;
    return span;
  }

  function formatPlain(d: GenData): string {
    const lines: string[] = [];
    lines.push(`SHOT LIST — ${d.format}`);
    lines.push(`Total: ${d.total_duration_sec.toFixed(1)}s · ${d.shot_count} shots`);
    if (d.duration_drift && d.target_duration_sec) {
      lines.push(`(drift warning: target was ~${d.target_duration_sec}s)`);
    }
    lines.push("");
    d.shots.forEach((s) => {
      const trans = s.transition_in && s.transition_in !== "cut" ? ` · ${s.transition_in}` : "";
      lines.push(`${String(s.shot_number).padStart(2, "0")}. [${s.duration_sec.toFixed(1)}s · ${s.framing}${trans}]`);
      lines.push(`    Action: ${s.action}`);
      lines.push(`    Audio: ${s.audio}`);
      if (s.notes) lines.push(`    Note: ${s.notes}`);
      lines.push("");
    });
    return lines.join("\n");
  }

  // ─── DEV-only test seam (stripped from production builds) ─────────────
  if (import.meta.env.DEV) {
    (window as any).__debug = {
      listProjects,
      getProject,
      saveProject,
      deleteProject,
      renameProject,
      duplicateProject,
      autoName,
      getLastViewedId,
      openProject,
      newProject,
      currentProjectId: () => currentProjectId,
    };
  }
</script>
