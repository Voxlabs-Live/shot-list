---
// ShotResult — renders the shot list as a stacked timeline of cards.
// Each shot shows: number, duration bar, framing chip, action, audio, optional
// transition + notes. Drift warning surfaces at top when sum is outside ±10%.
import {
  TRANSITION_ORDER,
  TRANSITION_GLOSSARY,
  FRAMING_ORDER,
  FRAMING_GLOSSARY,
} from "../lib/shot-glossary";
---
<section class="result" hidden>
  <header class="result__head">
    <div class="meta">
      <span class="meta__label">Shot list</span>
      <span class="meta__client" data-field="client"></span>
    </div>
    <div class="result__actions">
      <button class="btn btn--ghost btn--small" data-copy="json">
        Copy JSON
      </button>
      <button class="btn btn--ghost btn--small" data-copy="text">
        Copy as plain text
      </button>
    </div>
  </header>

  <div class="summary">
    <div class="summary__item">
      <span class="summary__label">Format</span>
      <span class="summary__val" data-field="format"></span>
    </div>
    <div class="summary__item">
      <span class="summary__label">Total duration</span>
      <span class="summary__val">
        <span data-field="total"></span><span class="summary__unit">s</span>
      </span>
    </div>
    <div class="summary__item">
      <span class="summary__label">Shots</span>
      <span class="summary__val" data-field="count"></span>
    </div>
  </div>

  <p class="drift" data-field="drift" hidden>
    Durations don&rsquo;t add up to the target window — review before shoot day.
  </p>

  <ol class="shots" data-field="shots"></ol>

  <details class="glossary">
    <summary class="glossary__summary">
      <span>Shot list terms, explained</span>
      <span class="glossary__chev" aria-hidden="true">&rsaquo;</span>
    </summary>
    <p class="glossary__lead">
      Tap any framing tag or transition chip above to see what it means in
      place — or skim the full set here.
    </p>

    <h4 class="glossary__group">Transitions</h4>
    <p class="glossary__note">
      The amber chip with the arrow. It only appears when the transition does
      real work — a plain cut has no chip.
    </p>
    <ul class="glossary__list">
      {TRANSITION_ORDER.map((token) => {
        const e = TRANSITION_GLOSSARY[token];
        return (
          <li class="glossary__item" id={`term-${token}`}>
            <p class="glossary__title">
              {e.title}
              <code class="glossary__token">{token}</code>
            </p>
            <p class="glossary__blurb">{e.blurb}</p>
            {e.example && <p class="glossary__example">e.g. {e.example}</p>}
          </li>
        );
      })}
    </ul>

    <h4 class="glossary__group">Framing &amp; angles</h4>
    <p class="glossary__note">
      The grey tag on every shot. These are written by the tool, so the exact
      wording varies — here are the common ones.
    </p>
    <ul class="glossary__list">
      {FRAMING_ORDER.map((token) => {
        const e = FRAMING_GLOSSARY[token];
        return (
          <li class="glossary__item">
            <p class="glossary__title">{e.title}</p>
            <p class="glossary__blurb">{e.blurb}</p>
          </li>
        );
      })}
    </ul>
  </details>
</section>

<style>
  .result {
    background: var(--surface-0);
    border: 1px solid var(--surface-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-top: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  @media (max-width: 600px) { .result { padding: 1.5rem; } }

  .result__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--surface-200);
  }
  .meta__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--surface-500);
    margin-right: 0.6rem;
  }
  .meta__client {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--surface-900);
  }
  .result__actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .summary {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px dashed var(--surface-200);
  }
  .summary__item { display: flex; flex-direction: column; gap: 0.2rem; }
  .summary__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--surface-500);
  }
  .summary__val {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--surface-900);
  }
  .summary__unit {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--surface-500);
    margin-left: 0.15rem;
  }

  .drift {
    background: oklch(from var(--accent-100) l c h / 0.5);
    border-left: 3px solid var(--accent-500);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: var(--text-sm);
    color: var(--accent-800);
  }

  .shots { list-style: none; padding: 0; margin: 0; }
  .shots :global(li) {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--surface-100);
  }
  .shots :global(li:last-child) { border-bottom: none; }
  .shots :global(.shot-num) {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    color: var(--surface-300);
    text-align: right;
    line-height: 1;
    padding-top: 0.15rem;
  }
  .shots :global(.shot-body) { display: flex; flex-direction: column; gap: 0.45rem; }
  .shots :global(.shot-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .shots :global(.chip) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm, 4px);
    background: var(--surface-100);
    color: var(--surface-700);
    border: 1px solid var(--surface-200);
  }
  .shots :global(.chip--duration) {
    background: oklch(from var(--accent-100) l c h / 0.7);
    color: var(--accent-800);
    border-color: oklch(from var(--accent-500) l c h / 0.4);
    font-weight: var(--font-weight-semibold);
  }
  .shots :global(.chip--transition) {
    background: oklch(from var(--amber-300) l c h / 0.18);
    color: var(--surface-900);
    border-color: oklch(from var(--amber-300) l c h / 0.5);
    font-style: italic;
  }
  .shots :global(.shot-action) {
    color: var(--surface-900);
    line-height: var(--leading-relaxed);
  }
  .shots :global(.shot-audio) {
    font-size: var(--text-sm);
    color: var(--surface-700);
  }
  .shots :global(.shot-audio-label) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    color: var(--surface-500);
    letter-spacing: 0.05em;
    margin-right: 0.4rem;
  }
  .shots :global(.shot-notes) {
    font-size: var(--text-sm);
    color: var(--surface-500);
    font-style: italic;
  }
  .shots :global(.shot-notes-label) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    font-style: normal;
    margin-right: 0.4rem;
  }

  /* Interactive chips: a quiet "there's more here" affordance, no loud icons. */
  .shots :global(.chip[role="button"]) {
    cursor: help;
    text-decoration: underline dotted;
    text-decoration-color: oklch(from currentColor l c h / 0.45);
    text-underline-offset: 2px;
  }
  .shots :global(.chip[role="button"]:hover) {
    text-decoration-color: currentColor;
  }
  .shots :global(.chip[role="button"]:focus-visible) {
    outline: 2px solid var(--accent-500);
    outline-offset: 2px;
  }

  /* ─── Glossary (collapsible "Shot list terms, explained") ───────────── */
  .glossary {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--surface-200);
  }
  .glossary__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--surface-900);
  }
  .glossary__summary::-webkit-details-marker { display: none; }
  .glossary__chev {
    font-family: var(--font-mono);
    color: var(--surface-500);
    transition: transform var(--duration-base, 0.18s) var(--ease-smooth, ease);
  }
  .glossary[open] .glossary__chev { transform: rotate(90deg); }
  .glossary__lead {
    margin: 0.75rem 0 1.25rem;
    font-size: var(--text-sm);
    color: var(--surface-500);
    max-width: 60ch;
  }
  .glossary__group {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--surface-600);
    margin: 1.25rem 0 0.25rem;
  }
  .glossary__note {
    margin: 0 0 0.85rem;
    font-size: var(--text-sm);
    color: var(--surface-500);
    max-width: 60ch;
  }
  .glossary__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1.5rem;
  }
  @media (max-width: 640px) {
    .glossary__list { grid-template-columns: 1fr; }
  }
  .glossary__item {
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--surface-100);
  }
  .glossary__title {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 0.25rem;
    font-weight: var(--font-weight-semibold);
    color: var(--surface-900);
  }
  .glossary__token {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-800);
    background: oklch(from var(--accent-100) l c h / 0.6);
    border: 1px solid oklch(from var(--accent-500) l c h / 0.3);
    border-radius: var(--radius-sm, 4px);
    padding: 0.05rem 0.4rem;
  }
  .glossary__blurb {
    margin: 0 0 0.2rem;
    font-size: var(--text-sm);
    color: var(--surface-700);
    line-height: var(--leading-relaxed);
  }
  .glossary__example {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--surface-500);
    font-style: italic;
  }
</style>
